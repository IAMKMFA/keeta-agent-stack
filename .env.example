# Database
DATABASE_URL=postgresql://keeta:keeta@localhost:5432/keeta_agent

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Feature flags
LIVE_MODE_ENABLED=false
ALLOW_DEV_SIGNER=true

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mock adapters (optional overrides)
MOCK_DEX_SPREAD_BPS=10
MOCK_DEX_FEE_BPS=5
MOCK_DEX_FAILURE_RATE=0
MOCK_ANCHOR_SETTLEMENT_DELAY_MS=0
