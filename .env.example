# Database
DATABASE_URL=postgresql://keeta:keeta@localhost:5432/keeta_agent

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=info
API_RATE_LIMIT_MAX=500
API_RATE_LIMIT_WINDOW_MS=60000
# Comma-separated IP allowlist for rate limiting bypass
API_RATE_LIMIT_ALLOWLIST=
# Comma-separated browser origins allowed to call the API. Empty allows all origins
# in development/test and disables cross-origin browser access in production.
API_CORS_ORIGINS=
# Swagger UI "try it out" defaults to true outside production and false in production.
# Set true only when exposing an intentionally interactive API console.
API_SWAGGER_TRY_IT_OUT_ENABLED=
OTEL_ENABLED=false
OTEL_CONSOLE_EXPORTER=false
OTEL_SERVICE_NAME=
# Example: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# Feature flags
LIVE_MODE_ENABLED=false
# Local development only. Production boot refuses ALLOW_DEV_SIGNER=true.
ALLOW_DEV_SIGNER=true

# Keeta (@keetanetwork/keetanet-client) — main | staging | test | dev
KEETA_NETWORK=test
# Worker-only: hex seed for live native transfers (never commit real seeds)
KEETA_SIGNING_SEED=
KEETA_ACCOUNT_INDEX=0
# Optional production BYOK signer. When KEETA_KMS_PROVIDER=gcp and KEETA_KMS_KEY
# are set, the worker uses Google Cloud KMS and KEETA_SIGNING_SEED is optional.
KEETA_KMS_PROVIDER=
# Format: projects/<project>/locations/<location>/keyRings/<ring>/cryptoKeys/<key>
# Optional version suffix: /cryptoKeyVersions/<version>
KEETA_KMS_KEY=
# Standard Google ADC credentials path for @google-cloud/kms in the worker.
GOOGLE_APPLICATION_CREDENTIALS=
# Optional explorer link template — replace {hash} with block/tx hash
KEETA_EXPLORER_TX_URL_TEMPLATE=
# KTA-Oracle service integration
KTA_ORACLE_BASE_URL=https://kta-oracle.vercel.app
KTA_ORACLE_TIMEOUT_MS=10000
# Require Keeta preflight hints in policy (worker populates from chain)
KEETA_POLICY_ENABLED=false
# Require intent.metadata identity signals (agentId, identityAttestation, identityCertFingerprint)
IDENTITY_POLICY_ENABLED=false
# Optional: partner HTTP endpoint for live oracle-rail-cctp-usdc execution (see adapter-oracle-rail)
# ORACLE_RAIL_CCTP_LIVE_URL=
# Require anchor bond lock references for live anchor policy checks
ANCHOR_BOND_STRICT=false
ANCHOR_BOND_RECONCILE_INTERVAL_MS=180000
ANCHOR_BOND_RECONCILE_BATCH_SIZE=250

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mock adapters (optional overrides)
MOCK_DEX_SPREAD_BPS=10
MOCK_DEX_FEE_BPS=5
MOCK_DEX_FAILURE_RATE=0
MOCK_ANCHOR_SETTLEMENT_DELAY_MS=0

# --- Operational Trust Layer ---
# Kill live execution in the worker (checked before each execute job)
EXECUTION_KILL_SWITCH=false
# Protect ops, webhook, events, and anchor-admin routes. Leave unset only in fully local dev.
OPS_API_KEY=
# Optional: POST /policy/evaluate (audited; does not bypass worker signing)
ADMIN_BYPASS_TOKEN=
# JWT auth for API operators/admins. Provide one of:
# AUTH_JWT_SECRET, AUTH_JWT_PUBLIC_KEY_PEM, AUTH_JWT_JWKS_URL, or AUTH_JWT_OIDC_DISCOVERY_URL / AUTH_JWT_OIDC_ISSUER.
AUTH_JWT_SECRET=
AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_JWT_JWKS_URL=
AUTH_JWT_OIDC_DISCOVERY_URL=
AUTH_JWT_OIDC_ISSUER=
AUTH_JWT_ISSUER=
# Comma-separated allowed audiences
AUTH_JWT_AUDIENCE=
# Timeout for remote JWKS / OIDC metadata lookups (ms)
AUTH_JWT_REMOTE_TIMEOUT_MS=5000
# Allow x-ops-key fallback outside development/test if you explicitly need it
AUTH_ALLOW_LEGACY_OPS_API_KEY=false
# Role granted when the legacy OPS_API_KEY is accepted. `operator` keeps admin mutations locked.
AUTH_LEGACY_OPS_API_KEY_ROLE=operator
# If false (the default), ADMIN_BYPASS_TOKEN is ignored in production. Set to `true` only if you
# must run ADMIN_BYPASS_TOKEN-backed automations in prod and understand the audit implications.
AUTH_ALLOW_ADMIN_BYPASS_IN_PRODUCTION=false

# MCP: allow inline `seed` arguments (DEV ONLY). When unset or false, the MCP server rejects
# any tool call that includes a `seed` argument and falls back to the worker-held
# `KEETA_SIGNING_SEED` environment variable so signing material never flows through
# tool transcripts or logs.
MCP_ALLOW_INLINE_SEEDS=false
# Optional: extend the pino secret-redaction list (comma-separated json-pointer-style paths).
LOG_REDACT_EXTRA=
# Expose Prometheus-compatible scrape output at /metrics
METRICS_ENABLED=true
# Require authenticated operator/admin access for /metrics
METRICS_REQUIRE_AUTH=true
# BullMQ job timeouts (ms) — see packages/config/src/bullmq.ts
JOB_TIMEOUT_MS_EXECUTE=120000
JOB_TIMEOUT_MS_POLICY=60000
JOB_TIMEOUT_MS_ROUTE=60000
JOB_TIMEOUT_MS_QUOTE=60000
JOB_TIMEOUT_MS_ANCHOR_BOND_RECONCILE=120000
JOB_TIMEOUT_MS_ANCHOR_ONBOARDING=120000
RECONCILE_INTERVAL_MS=300000
METRICS_INTERVAL_MS=60000
STUCK_JOB_SWEEP_INTERVAL_MS=120000
STUCK_JOB_AGE_MS=600000
# Dynamic operator intelligence — how often to aggregate execution outcomes into routing signals
OPERATOR_METRICS_INTERVAL_MS=300000
# TTL for operator metrics in Redis cache at routing time (ms)
OPERATOR_METRICS_TTL_MS=300000
# p95 latency above this threshold earns an anchor a latency penalty (ms)
OPERATOR_LATENCY_P95_THRESHOLD_MS=30000
# Success rate below this triggers a penalty; below 80 triggers a block (0–100)
OPERATOR_SUCCESS_RATE_MIN_PCT=95
# Webhook retries stop after this many attempts and remain failed
WEBHOOK_DELIVERY_MAX_ATTEMPTS=5
# Shutdown timeout for workers/queues before the process logs and moves on
WORKER_SHUTDOWN_TIMEOUT_MS=30000
# Portfolio policy caps (optional; 0 or unset disables a rule)
POLICY_MAX_DAILY_TRADES=50000
POLICY_MAX_UNSETTLED=5000
POLICY_MAX_EXPOSURE_PER_ASSET=
POLICY_MAX_EXPOSURE_PER_WALLET=
POLICY_MAX_EXPOSURE_PER_VENUE=
POLICY_MAX_NOTIONAL_PER_STRATEGY=
POLICY_MAX_DRAWDOWN_BPS=

# Dashboard: surface mock vs live posture (optional)
MOCK_ADAPTERS=true
