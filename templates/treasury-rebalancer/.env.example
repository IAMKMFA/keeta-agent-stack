# API URL. The local dev stack runs at :3001.
# Set this to your own sandbox or production deployment when available.
KEETA_API_URL=http://localhost:3001

# Optional bearer token. Leave blank against the public sandbox.
# Required against any deployment that has OPS_API_KEY set on the API.
KEETA_API_TOKEN=

# Wallet that the rebalancer manages. Generate one with:
#   curl -X POST $KEETA_API_URL/wallets -d '{"label":"treasury"}'
KEETA_WALLET_ID=

# Cadence in seconds for the rebalance loop. Default = 60s.
REBALANCE_INTERVAL_SECONDS=60

# Drift threshold (basis points). Skip the rebalance leg unless the wallet's
# allocation has drifted more than this from the target. Default = 200 (2%).
REBALANCE_DRIFT_THRESHOLD_BPS=200

# Hard caps mirrored into the policy pack. The agent will refuse any leg
# that exceeds these.
REBALANCE_MAX_LEG_NOTIONAL=10000
REBALANCE_MAX_SLIPPAGE_BPS=50

# Mode for emitted intents. 'simulate' is safe against the sandbox.
# Switch to 'live' against your own deployment with a funded wallet.
REBALANCE_INTENT_MODE=simulate
