{
  "name": "keeta-agent-sdk",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --filter=@keeta-agent-sdk/api --filter=@keeta-agent-sdk/worker --filter=@keeta-agent-sdk/dashboard",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @keeta-agent-sdk/storage exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @keeta-agent-sdk/storage exec tsx src/migrate.ts",
    "db:seed": "pnpm --filter @keeta-agent-sdk/storage exec tsx src/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
