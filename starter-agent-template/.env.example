# Base URL for the Keeta API control plane (the dev stack runs at :3001).
KEETA_API_URL=http://localhost:3001

# Bearer token issued by your Keeta tenant. Required for live mode; the smoke
# script will run in offline (registry-backed) mode if this is left blank.
KEETA_API_TOKEN=

# Drives src/index.ts — choose which intent shape to dispatch on `pnpm start`.
# Supported values: payment, rebalance
INTENT_KIND=payment
