{
  "name": "@keeta-agent-stack/adapter-x402",
  "version": "0.1.0-alpha.0",
  "description": "x402 agent-payment rail adapter for Keeta Agent Stack",
  "license": "Apache-2.0",
  "author": "Keeta Agent Stack contributors",
  "homepage": "https://github.com/IAMKMFA/keeta-agent-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IAMKMFA/keeta-agent-stack.git",
    "directory": "packages/adapter-x402"
  },
  "bugs": {
    "url": "https://github.com/IAMKMFA/keeta-agent-stack/issues"
  },
  "keywords": [
    "keeta",
    "adapter",
    "x402",
    "agent-payments"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-stack/adapter-base": "workspace:*",
    "@keeta-agent-stack/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
