{
  "name": "@keeta-agent-sdk/config",
  "version": "0.1.0-alpha.0",
  "description": "@keeta-agent-sdk/config - part of the Keeta Agent SDK",
  "license": "Apache-2.0",
  "author": "Keeta Agent SDK contributors",
  "homepage": "https://github.com/IAMKMFA/keeta-agent-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IAMKMFA/keeta-agent-sdk.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/IAMKMFA/keeta-agent-sdk/issues"
  },
  "keywords": [
    "keeta",
    "config"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
