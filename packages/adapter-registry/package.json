{
  "name": "@keeta-agent-sdk/adapter-registry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-sdk/types": "workspace:*",
    "@keeta-agent-sdk/adapter-base": "workspace:*",
    "@keeta-agent-sdk/adapter-mock-anchor": "workspace:*",
    "@keeta-agent-sdk/adapter-mock-dex": "workspace:*",
    "@keeta-agent-sdk/adapter-keeta-transfer": "workspace:*",
    "@keeta-agent-sdk/adapter-oracle-rail": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
