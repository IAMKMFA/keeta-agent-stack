    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-sdk/types": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
