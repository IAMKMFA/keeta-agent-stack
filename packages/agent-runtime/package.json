{
  "name": "@keeta-agent-stack/agent-runtime",
  "version": "0.1.0-alpha.0",
  "description": "@keeta-agent-stack/agent-runtime - part of the Keeta Agent Stack",
  "license": "Apache-2.0",
  "author": "Keeta Agent Stack contributors",
  "homepage": "https://github.com/IAMKMFA/keeta-agent-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IAMKMFA/keeta-agent-stack.git",
    "directory": "packages/agent-runtime"
  },
  "bugs": {
    "url": "https://github.com/IAMKMFA/keeta-agent-stack/issues"
  },
  "keywords": [
    "keeta",
    "agent",
    "runtime",
    "autonomous",
    "orchestration"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-stack/adapter-registry": "workspace:*",
    "@keeta-agent-stack/policy": "workspace:*",
    "@keeta-agent-stack/routing": "workspace:*",
    "@keeta-agent-stack/sdk": "workspace:*",
    "@keeta-agent-stack/simulator": "workspace:*",
    "@keeta-agent-stack/types": "workspace:*",
    "@keeta-agent-stack/wallet": "workspace:*"
  },
  "devDependencies": {
    "@keeta-agent-stack/adapter-mock-dex": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
