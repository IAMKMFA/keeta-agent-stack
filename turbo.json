{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "NODE_ENV",
    "API_PORT",
    "LOG_LEVEL",
    "NEXT_PUBLIC_API_URL",
    "KTA_ORACLE_BASE_URL",
    "KTA_ORACLE_TIMEOUT_MS"
  ]
}
