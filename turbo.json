{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:security": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "NODE_ENV",
    "API_PORT",
    "LOG_LEVEL",
    "API_CORS_ORIGINS",
    "API_SWAGGER_TRY_IT_OUT_ENABLED",
    "NEXT_PUBLIC_API_URL",
    "KTA_ORACLE_BASE_URL",
    "KTA_ORACLE_TIMEOUT_MS",
    "KEETA_NETWORK",
    "KEETA_SIGNING_SEED",
    "KEETA_ACCOUNT_INDEX",
    "KEETA_POLICY_ENABLED",
    "IDENTITY_POLICY_ENABLED",
    "ANCHOR_BOND_STRICT",
    "LIVE_MODE_ENABLED",
    "MCP_ALLOW_INLINE_SEEDS",
    "OPS_API_KEY",
    "RUN_INTEGRATION_TESTS",
    "INTEGRATION_DATABASE_URL",
    "INTEGRATION_ADMIN_DATABASE_URL",
    "INTEGRATION_REDIS_URL",
    "INTEGRATION_OPS_API_KEY",
    "INTEGRATION_DATABASE_NAME",
    "ADMIN_BYPASS_TOKEN",
    "AUTH_ALLOW_LEGACY_OPS_API_KEY",
    "AUTH_LEGACY_OPS_API_KEY_ROLE",
    "AUTH_ALLOW_ADMIN_BYPASS_IN_PRODUCTION"
  ]
}
