{
  "name": "@keeta-agent-stack/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-stack/adapter-registry": "workspace:*",
    "@keeta-agent-stack/config": "workspace:*",
    "@keeta-agent-stack/keeta": "workspace:*",
    "@keeta-agent-stack/policy": "workspace:*",
    "@keeta-agent-stack/routing": "workspace:*",
    "@keeta-agent-stack/simulator": "workspace:*",
    "@keeta-agent-stack/storage": "workspace:*",
    "@keeta-agent-stack/telemetry": "workspace:*",
    "@keeta-agent-stack/types": "workspace:*",
    "@keeta-agent-stack/utils": "workspace:*",
    "bullmq": "^5.34.5",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
