{
  "name": "@keeta-agent-sdk/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keeta-agent-sdk/adapter-registry": "workspace:*",
    "@keeta-agent-sdk/config": "workspace:*",
    "@keeta-agent-sdk/policy": "workspace:*",
    "@keeta-agent-sdk/routing": "workspace:*",
    "@keeta-agent-sdk/simulator": "workspace:*",
    "@keeta-agent-sdk/storage": "workspace:*",
    "@keeta-agent-sdk/telemetry": "workspace:*",
    "@keeta-agent-sdk/types": "workspace:*",
    "bullmq": "^5.34.5",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
