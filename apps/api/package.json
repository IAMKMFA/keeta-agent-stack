{
  "name": "@keeta-agent-sdk/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --clean",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@keeta-agent-sdk/adapter-registry": "workspace:*",
    "@keeta-agent-sdk/config": "workspace:*",
    "@keeta-agent-sdk/keeta": "workspace:*",
    "@keeta-agent-sdk/storage": "workspace:*",
    "@keeta-agent-sdk/telemetry": "workspace:*",
    "@keeta-agent-sdk/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "bullmq": "^5.34.5",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
