{
  "name": "@keeta-agent-stack/mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "docs:tools": "tsx scripts/dump-tools.ts"
  },
  "dependencies": {
    "@keeta-agent-stack/custody-guards": "workspace:*",
    "@keeta-agent-stack/keeta": "workspace:*",
    "@keeta-agent-stack/policy": "workspace:*",
    "@keeta-agent-stack/sdk": "workspace:*",
    "@keetanetwork/anchor": "^0.0.60",
    "@keetanetwork/keetanet-client": "^0.16.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "zod-to-json-schema": "^3.25.2"
  }
}
